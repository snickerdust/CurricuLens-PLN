{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "backend/**",
      "venv/**",
      "*.ipynb",
      "__pycache__/**",
      "*.zip",
      "*.md"
    ],
    "rewrites": [
      {
        "source": "/testing",
        "destination": "/testing.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
