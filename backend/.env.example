# Salin file ini menjadi .env dan isi nilainya

# Path ke file credentials Firebase (service account JSON)
GOOGLE_APPLICATION_CREDENTIALS=firebase_credentials.json

# Nama project Firebase (opsional, untuk validasi)
FIREBASE_PROJECT_ID=your-project-id

# Izinkan origin dari frontend (pisahkan dengan koma jika lebih dari satu)
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,null
